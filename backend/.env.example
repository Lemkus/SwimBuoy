# Скопируйте в .env и заполните для прода.

# Публичный URL портала (для share-ссылок и подсказок в watch-app).
SWIMBUOY_BASE_URL=https://swimbuy.iron-siber.ru

# Токен администратора для создания спортсменов (POST /api/athletes).
# Сгенерируйте: python -c "import secrets; print(secrets.token_urlsafe(32))"
SWIMBUOY_ADMIN_TOKEN=change-me-admin-token

# Каталог данных (SQLite + загруженные файлы).
SWIMBUOY_DATA_DIR=data

# CORS: "*" или список origin через запятую.
SWIMBUOY_CORS_ORIGINS=*

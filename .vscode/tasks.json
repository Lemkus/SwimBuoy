{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "SwimBuoy: Build and Run",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/build-and-run.bat",
            "windows": {
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": ["/d", "/c"]
                    }
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
